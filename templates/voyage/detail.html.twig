{% extends 'base.html.twig' %}

{% block title %}Detail - {{ voyage.destination }}{% endblock %}

{% block body %}
<section class="voyage-detail">
    <h1>{{ voyage.destination }}</h1>

    {% if voyage.imageUrl %}
        <img src="{{ voyage.imageUrl }}" alt="{{ voyage.destination }}" style="max-width: 900px; width: 100%; border-radius: 12px">
    {% endif %}

    <p>formule : {{ voyage.formule.nom }}</p>
    <p>prix : {{ voyage.prix }} EUR</p>

    <section class="activites">
        <h2>Activites autour de {{ voyage.destination }}</h2>

        {% for activite in activites %}
            <article class="activite-card">
                <div class="activite-contenu">
                    <h3 class="activite-name">{{ activite.titre|default('titre non disponible') }}</h3>
                    <p class="activite-address">{{ activite.lieu|default('Lieu non disponible') }}</p>
                    <p class="activite-category">{{ activite.description|default('Description non disponible') }}</p>
                    <p class="activite-category">{{ activite.date ? activite.date|date('d/m/Y') : 'Date non disponible' }}</p>
                    {% if activite.image %}
                        <img src="{{ activite.image }}" alt="{{ activite.titre }}">
                    {% else %}
                        <p>Aucune image pour cette activite</p>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <p>Aucune activite disponible pour le moment.</p>
        {% endfor %}
    </section>

    <a href="{{ path('app_voyage') }}">Retour</a>
</section>
{% endblock %}
